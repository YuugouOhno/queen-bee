{
  "modes": {
    "QB_QUEEN": {
      "context": ["queen.md"],
      "skip_log": false,
      "description": "queen-bee L1: Queen (orchestrator)"
    },
    "QB_LEADER": {
      "context": ["leader.md"],
      "skip_log": false,
      "description": "queen-bee L2: Leader (implementation lead)"
    },
    "QB_REVIEW_LEADER": {
      "context": ["review-leader.md"],
      "skip_log": false,
      "description": "queen-bee L2: Review Leader (review lead)"
    },
    "QB_WORKER_CODER": {
      "context": ["executor.md"],
      "skip_log": false,
      "description": "queen-bee L3: Worker (implementation)"
    },
    "QB_WORKER_TESTER": {
      "context": ["executor.md", "tester.md"],
      "skip_log": false,
      "description": "queen-bee L3: Worker (test writing)"
    },
    "QB_WORKER_CODE_REVIEWER": {
      "context": ["reviewer-base.md", "code-reviewer.md"],
      "skip_log": false,
      "description": "queen-bee L3: Worker (code review)"
    },
    "QB_WORKER_SECURITY": {
      "context": ["reviewer-base.md", "security-reviewer.md"],
      "skip_log": false,
      "description": "queen-bee L3: Worker (security review)"
    },
    "QB_WORKER_TEST_AUDITOR": {
      "context": ["reviewer-base.md", "test-auditor.md"],
      "skip_log": false,
      "description": "queen-bee L3: Worker (test audit)"
    }
  },
  "roles": {
    "leader": {
      "env_var": "QB_LEADER",
      "allowed_tools": "Read Write Edit Bash Glob Grep Skill",
      "max_turns": 80,
      "description": "queen-bee: implementation lead for an Issue"
    },
    "review-leader": {
      "env_var": "QB_REVIEW_LEADER",
      "allowed_tools": "Read Grep Glob Bash Skill",
      "max_turns": 40,
      "description": "queen-bee: review lead for a PR"
    },
    "worker-coder": {
      "env_var": "QB_WORKER_CODER",
      "allowed_tools": "Read Write Edit Bash Glob Grep",
      "max_turns": 30,
      "description": "queen-bee: single subtask implementation"
    },
    "worker-tester": {
      "env_var": "QB_WORKER_TESTER",
      "allowed_tools": "Read Write Edit Bash Glob Grep",
      "max_turns": 30,
      "description": "queen-bee: test writing for a subtask"
    },
    "worker-code-reviewer": {
      "env_var": "QB_WORKER_CODE_REVIEWER",
      "allowed_tools": "Read Grep Glob Bash",
      "max_turns": 15,
      "description": "queen-bee: code quality review"
    },
    "worker-security": {
      "env_var": "QB_WORKER_SECURITY",
      "allowed_tools": "Read Grep Glob Bash",
      "max_turns": 15,
      "description": "queen-bee: security review"
    },
    "worker-test-auditor": {
      "env_var": "QB_WORKER_TEST_AUDITOR",
      "allowed_tools": "Read Grep Glob Bash",
      "max_turns": 15,
      "description": "queen-bee: test audit"
    }
  },
  "default_context": "default.md"
}
